  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "comment.block",
        "comment.line"
      ],
      "settings": {
        "foreground": "#6C7392",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comment Documentation / JSDoc",
      "scope": [
        "comment.block.documentation",
        "comment.block.documentation storage.type",
        "keyword.other.documentation"
      ],
      "settings": {
        "foreground": "#7E86A8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.quoted.single",
        "string.quoted.double",
        "string.template",
        "string.unquoted",
        "punctuation.definition.string.begin",
        "punctuation.definition.string.end"
      ],
      "settings": {
        "foreground": "#A5E075"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "constant.character.string.escape",
        "string.regexp constant.character.escape"
      ],
      "settings": {
        "foreground": "#5FD7C4"
      }
    },
    {
      "name": "Regular Expression",
      "scope": [
        "string.regexp",
        "punctuation.definition.character-class"
      ],
      "settings": {
        "foreground": "#5FD7C4"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float",
        "constant.numeric.hex",
        "constant.numeric.decimal"
      ],
      "settings": {
        "foreground": "#F5A25C"
      }
    },
    {
      "name": "Boolean / Null / Language Constant",
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity"
      ],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Constant / Enum member",
      "scope": [
        "constant.other",
        "constant.other.caps",
        "variable.other.constant",
        "constant.character"
      ],
      "settings": {
        "foreground": "#F5A25C"
      }
    },
    {
      "name": "Keyword (SIGNATURE — bold accent)",
      "scope": [
        "keyword",
        "keyword.other",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical",
        "keyword.operator.delete",
        "keyword.operator.instanceof",
        "keyword.operator.typeof",
        "keyword.operator.void"
      ],
      "settings": {
        "foreground": "#FF6B9D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Control Flow Keyword (SIGNATURE — bold accent)",
      "scope": [
        "keyword.control",
        "keyword.control.flow",
        "keyword.control.conditional",
        "keyword.control.loop",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as",
        "keyword.control.return",
        "keyword.control.trycatch",
        "keyword.control.exception"
      ],
      "settings": {
        "foreground": "#FF6B9D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Storage (SIGNATURE — bold accent)",
      "scope": [
        "storage",
        "storage.type",
        "storage.type.function",
        "storage.type.class",
        "storage.type.enum",
        "storage.type.interface",
        "storage.type.namespace",
        "storage.modifier",
        "storage.modifier.async",
        "storage.modifier.static",
        "keyword.declaration"
      ],
      "settings": {
        "foreground": "#FF6B9D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "keyword.operator.arithmetic",
        "keyword.operator.assignment",
        "keyword.operator.comparison",
        "keyword.operator.relational",
        "keyword.operator.bitwise",
        "keyword.operator.ternary"
      ],
      "settings": {
        "foreground": "#5FD7C4"
      }
    },
    {
      "name": "Function / Method Definition",
      "scope": [
        "entity.name.function",
        "meta.function-call entity.name.function",
        "support.function",
        "meta.definition.method entity.name.function"
      ],
      "settings": {
        "foreground": "#6BC1FF"
      }
    },
    {
      "name": "Function Call",
      "scope": [
        "meta.function-call",
        "variable.function"
      ],
      "settings": {
        "foreground": "#6BC1FF"
      }
    },
    {
      "name": "Macro / Preprocessor",
      "scope": [
        "entity.name.function.preprocessor",
        "meta.preprocessor",
        "keyword.control.directive"
      ],
      "settings": {
        "foreground": "#C792EA"
      }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.type.class",
        "entity.name.class",
        "entity.name.type.interface",
        "entity.name.type.enum",
        "entity.other.inherited-class",
        "support.class",
        "support.type"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "name": "Primitive / Built-in Type",
      "scope": [
        "support.type.primitive",
        "storage.type.built-in",
        "support.type.builtin"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Namespace / Module",
      "scope": [
        "entity.name.namespace",
        "entity.name.module",
        "support.other.namespace"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.other.readwrite",
        "meta.definition.variable variable.other"
      ],
      "settings": {
        "foreground": "#E4E6F1"
      }
    },
    {
      "name": "Parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter",
        "variable.parameter.function"
      ],
      "settings": {
        "foreground": "#E8B98A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Object Property / Key",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.type.property-name",
        "meta.object-literal.key",
        "meta.object.member"
      ],
      "settings": {
        "foreground": "#8FD1FF"
      }
    },
    {
      "name": "Language Variable (this / self / super)",
      "scope": [
        "variable.language",
        "variable.language.this",
        "variable.language.super",
        "keyword.other.this"
      ],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic bold"
      }
    },
    {
      "name": "Built-in / Global (console, window, etc.)",
      "scope": [
        "support.variable",
        "support.constant",
        "variable.other.global"
      ],
      "settings": {
        "foreground": "#5FD7C4"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator",
        "punctuation.definition.parameters",
        "punctuation.definition.array",
        "meta.brace.round",
        "meta.brace.square",
        "punctuation.section"
      ],
      "settings": {
        "foreground": "#8B92B0"
      }
    },
    {
      "name": "Punctuation Accessor / Delimiter",
      "scope": [
        "punctuation.accessor",
        "punctuation.separator.key-value",
        "punctuation.separator.dictionary.key-value"
      ],
      "settings": {
        "foreground": "#8B92B0"
      }
    },
    {
      "name": "Decorator / Annotation",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator",
        "storage.type.annotation",
        "meta.annotation"
      ],
      "settings": {
        "foreground": "#C792EA",
        "fontStyle": "italic"
      }
    },
    {
      "name": "HTML / XML / JSX Tag",
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html",
        "entity.name.tag.xml",
        "meta.tag",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#FF6B9D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "HTML / XML Attribute",
      "scope": [
        "entity.other.attribute-name",
        "entity.other.attribute-name.html",
        "entity.other.attribute-name.class",
        "entity.other.attribute-name.id"
      ],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "italic"
      }
    },
    {
      "name": "CSS Property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#6BC1FF"
      }
    },
    {
      "name": "CSS Value / Unit",
      "scope": [
        "support.constant.property-value.css",
        "keyword.other.unit.css",
        "constant.numeric.css"
      ],
      "settings": {
        "foreground": "#F5A25C"
      }
    },
    {
      "name": "CSS Selector",
      "scope": [
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.name.tag.css"
      ],
      "settings": {
        "foreground": "#FFD166"
      }
    },
    {
      "name": "Markdown Heading",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#FF6B9D",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": ["markup.bold"],
      "settings": {
        "foreground": "#F5A25C",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": ["markup.italic"],
      "settings": {
        "foreground": "#FFD166",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Link",
      "scope": [
        "markup.underline.link",
        "string.other.link.title.markdown"
      ],
      "settings": {
        "foreground": "#6BC1FF"
      }
    },
    {
      "name": "Markdown Inline Code / Quote",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#A5E075"
      }
    },
    {
      "name": "Markdown Quote",
      "scope": ["markup.quote"],
      "settings": {
        "foreground": "#8B92B0",
        "fontStyle": "italic"
      }
    },
    {
      "name": "JSON Key",
      "scope": [
        "support.type.property-name.json",
        "meta.structure.dictionary.key.json"
      ],
      "settings": {
        "foreground": "#6BC1FF"
      }
    },
    {
      "name": "Invalid / Error",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FF5C7A",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Invalid Deprecated",
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#FF7B93",
        "fontStyle": "strikethrough"
      }
    },
    {
      "name": "Diff Inserted",
